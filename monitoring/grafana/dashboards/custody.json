{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "출금 (Withdrawal)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(custody_withdrawal_created_total{application=\"custody\"}[1m])",
          "legendFormat": "created/s",
          "refId": "A"
        },
        {
          "expr": "rate(custody_withdrawal_broadcasted_total{application=\"custody\"}[1m])",
          "legendFormat": "broadcasted/s",
          "refId": "B"
        }
      ],
      "title": "출금 생성·브로드캐스트 속도",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(custody_withdrawal_policy_rejected_total{application=\"custody\"}[1m])",
          "legendFormat": "rejected ({{reason}})",
          "refId": "A"
        }
      ],
      "title": "정책 거부율 (reason별)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(custody_withdrawal_create_duration_seconds_bucket{application=\"custody\"}[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(custody_withdrawal_create_duration_seconds_bucket{application=\"custody\"}[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(custody_withdrawal_create_duration_seconds_bucket{application=\"custody\"}[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "출금 생성 소요 시간 (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "컨펌 추적 (Confirmation Tracker)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 50 }
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "expr": "custody_confirmation_tracker_active_tasks{application=\"custody\"}",
          "legendFormat": "active tasks",
          "refId": "A"
        }
      ],
      "title": "현재 추적 중인 TX 수",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 10 },
      "id": 5,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "increase(custody_confirmation_tracker_timeout_total{application=\"custody\"}[10m])",
          "legendFormat": "timeout (10m)",
          "refId": "A"
        }
      ],
      "title": "TX 컨펌 타임아웃 (10분 누적)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 10 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(custody_withdrawal_retry_total{application=\"custody\"}[1m])",
          "legendFormat": "retry/s",
          "refId": "A"
        },
        {
          "expr": "rate(custody_withdrawal_replace_total{application=\"custody\"}[1m])",
          "legendFormat": "replace/s",
          "refId": "B"
        }
      ],
      "title": "Retry / Replace 속도",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "RPC 호출 (Chain Adapter)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(custody_rpc_call_total{application=\"custody\", success=\"true\"}[1m])",
          "legendFormat": "{{method}} OK",
          "refId": "A"
        },
        {
          "expr": "rate(custody_rpc_call_total{application=\"custody\", success=\"false\"}[1m])",
          "legendFormat": "{{method}} ERR",
          "refId": "B"
        }
      ],
      "title": "RPC 호출 속도 (method·성공여부)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(custody_rpc_call_duration_seconds_bucket{application=\"custody\"}[5m]))",
          "legendFormat": "P95 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(custody_rpc_call_duration_seconds_bucket{application=\"custody\"}[5m]))",
          "legendFormat": "P99 {{method}}",
          "refId": "B"
        }
      ],
      "title": "RPC 응답 시간 P95/P99 (method별)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(custody_rpc_call_total{application=\"custody\", success=\"false\"}[5m]) / rate(custody_rpc_call_total{application=\"custody\"}[5m])",
          "legendFormat": "error rate {{method}}",
          "refId": "A"
        }
      ],
      "title": "RPC 에러율 (method별)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 10,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "increase(custody_rpc_call_total{application=\"custody\"}[1h])",
          "legendFormat": "{{method}} (success={{success}})",
          "refId": "A"
        }
      ],
      "title": "RPC 호출 수 (1시간 누적)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["custody"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Custody 운영 대시보드",
  "uid": "custody-ops",
  "version": 1
}
